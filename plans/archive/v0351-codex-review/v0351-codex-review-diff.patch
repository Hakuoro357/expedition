   setLocale(locale: Locale): void {
     this.locale = locale;
-    document.documentElement.lang = locale;
+    // Guard для test-env (vitest без jsdom): document может не существовать.
+    // В браузере и в playwright всегда есть.
+    if (typeof document !== "undefined") {
+      document.documentElement.lang = locale;
